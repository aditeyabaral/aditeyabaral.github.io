---
layout: page
---
<div class="talk">
  {% if page.series or page.venue %}
    <div class="talk-info">
      {% if page.series %}
        <p><strong>Series:</strong> {{ page.series }}</p>
      {% endif %}
      {% if page.venue %}
        <p><strong>Venue:</strong> {{ page.venue }}{% if page.location %}, {{ page.location }}{% endif %}</p>
      {% endif %}
      {% if page.date %}
        <p><strong>Date:</strong> {{ page.date | date: "%B %-d, %Y" }}</p>
      {% endif %}
    </div>
  {% endif %}

  {{ content }}

  {% if page.materials %}
    <h2>Materials</h2>
    <ul>
      {% for material in page.materials %}
        <li>
          {% if material.url %}
            {% if material.url contains '://' %}
              <a href="{{ material.url }}" target="_blank">{{ material.name }}</a>
            {% else %}
              <a href="{{ material.url | relative_url }}" target="_blank">{{ material.name }}</a>
            {% endif %}
          {% else %}
            {{ material.name }}
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}
</div>
